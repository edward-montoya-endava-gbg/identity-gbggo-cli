# goctl — example env-var file.
#
# Copy to `.env` and fill in real values. The CLI does NOT auto-load `.env`;
# export the vars (e.g. `set -a; source .env; set +a`) or use direnv /
# 1Password CLI / your preferred secrets manager.
#
# The names below match the defaults declared in `regions.example.yaml`.
# If you rename anything in your `regions.yaml`, rename it here too.

# ─────────────────────────────────────────────────────────────────────────────
# Captain v1 (base path: /captain/api)
# ─────────────────────────────────────────────────────────────────────────────

# dev
GGO_CAPTAIN_V1_DEV_CLIENT_ID=flow-api-test
GGO_CAPTAIN_V1_DEV_USERNAME=
GGO_CAPTAIN_V1_DEV_PASSWORD=
GGO_CAPTAIN_V1_DEV_CLIENT_SECRET=

# demo
GGO_CAPTAIN_V1_DEMO_CLIENT_ID=flow-api-test
GGO_CAPTAIN_V1_DEMO_USERNAME=
GGO_CAPTAIN_V1_DEMO_PASSWORD=
GGO_CAPTAIN_V1_DEMO_CLIENT_SECRET=

# prod
GGO_CAPTAIN_V1_PROD_CLIENT_ID=
GGO_CAPTAIN_V1_PROD_USERNAME=
GGO_CAPTAIN_V1_PROD_PASSWORD=
GGO_CAPTAIN_V1_PROD_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Captain v2 (base path: /v2/captain)
# ─────────────────────────────────────────────────────────────────────────────

# dev
GGO_CAPTAIN_V2_DEV_CLIENT_ID=flow-api-test
GGO_CAPTAIN_V2_DEV_USERNAME=
GGO_CAPTAIN_V2_DEV_PASSWORD=
GGO_CAPTAIN_V2_DEV_CLIENT_SECRET=

# demo
GGO_CAPTAIN_V2_DEMO_CLIENT_ID=flow-api-test
GGO_CAPTAIN_V2_DEMO_USERNAME=
GGO_CAPTAIN_V2_DEMO_PASSWORD=
GGO_CAPTAIN_V2_DEMO_CLIENT_SECRET=

# prod
GGO_CAPTAIN_V2_PROD_CLIENT_ID=
GGO_CAPTAIN_V2_PROD_USERNAME=
GGO_CAPTAIN_V2_PROD_PASSWORD=
GGO_CAPTAIN_V2_PROD_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Designer (base path: /designer/api) — prod is bearer-only, no env vars
# ─────────────────────────────────────────────────────────────────────────────

# dev
GGO_DESIGNER_DEV_CLIENT_ID=flow-api-test
GGO_DESIGNER_DEV_USERNAME=
GGO_DESIGNER_DEV_PASSWORD=
GGO_DESIGNER_DEV_CLIENT_SECRET=

# demo
GGO_DESIGNER_DEMO_CLIENT_ID=flow-api-test
GGO_DESIGNER_DEMO_USERNAME=
GGO_DESIGNER_DEMO_PASSWORD=
GGO_DESIGNER_DEMO_CLIENT_SECRET=

# prod: bearer-only — use GGO_BEARER_TOKEN (see bottom).

# ─────────────────────────────────────────────────────────────────────────────
# UserView (base path: /view/api) — prod is bearer-only, no env vars
# ─────────────────────────────────────────────────────────────────────────────

# dev
GGO_USERVIEW_DEV_CLIENT_ID=userview-full
GGO_USERVIEW_DEV_USERNAME=
GGO_USERVIEW_DEV_PASSWORD=
GGO_USERVIEW_DEV_CLIENT_SECRET=

# demo
GGO_USERVIEW_DEMO_CLIENT_ID=userview-full
GGO_USERVIEW_DEMO_USERNAME=
GGO_USERVIEW_DEMO_PASSWORD=
GGO_USERVIEW_DEMO_CLIENT_SECRET=

# prod: bearer-only — use GGO_BEARER_TOKEN (see bottom).

# ─────────────────────────────────────────────────────────────────────────────
# Bearer override (skips OAuth flow for any tuple)
# ─────────────────────────────────────────────────────────────────────────────

# Set this when you already have a bearer token (any service / env).
# Required for Designer prod and UserView prod since they're bearer-only.
# GGO_BEARER_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# goctl runtime
# ─────────────────────────────────────────────────────────────────────────────

# Override the regions.yaml lookup path (otherwise XDG defaults apply).
# GOCTL_CONFIG=/absolute/path/to/regions.yaml

# Template-variable defaults — GGO_VAR_<UPPER_KEY> sets a default for `--var <key>`.
# Example:
# GGO_VAR_LOCALE=en-US
